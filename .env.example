# App
PORT=3001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=stellarpass

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Stellar
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
EVENT_CONTRACT_ID=<deployed_event_contract_id>
TICKET_CONTRACT_ID=<deployed_ticket_contract_id>
PAYMENT_CONTRACT_ID=<deployed_payment_contract_id>

# USDC token contract on testnet
USDC_CONTRACT_ID=<usdc_token_contract_id>

# Pinata IPFS
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_GATEWAY=https://gateway.pinata.cloud

# Email (for password reset)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@stellarpass.io

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000
